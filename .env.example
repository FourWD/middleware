# =============================================================================
# .env.example — template for all environment variables used by the middleware.
# Copy to .env.{env} (e.g. .env.dev, .env.prod) and fill in real values.
# NEVER commit the filled copies — only this file (no secrets).
# =============================================================================

# ============================================================================
# App identity
# ============================================================================
# APP_ID is the service identifier used everywhere (logs, metrics, OTel,
# JWT issuer, rate-limit key prefix, SMS/Upload business ID).
# On Google App Engine the GAE_SERVICE env (set automatically) takes precedence.
APP_ID=                # required
APP_ENV=local          # local | dev | prod | test
APP_VERSION=           # e.g. 25.10.15
APP_TIMEZONE=Asia/Bangkok
APP_ENCRYPT_KEY=       # AES-GCM key material (hashed with SHA-256 before use)

# ============================================================================
# HTTP
# ============================================================================
HTTP_ADDRESS=8080                                 # port only (e.g. 8080) or host:port (e.g. 0.0.0.0:8080)
HTTP_ALLOW_ORIGINS=*
HTTP_PUBLIC_PATHS=/metrics,/wake-up,/_ah/warmup   # CSV — routes that skip auth
HTTP_PROXY_HEADER=
HTTP_DEBUG_AUTH_TOKEN=                            # ≥16 chars if set
HTTP_ENVELOPE_ENABLED=false                       # true → wrap JSON response as {success, data, error}

# Request log verbosity — set to false to include bodies/headers in request log
HTTP_REQUEST_LOG_OMIT_REQUEST_BODY=true
HTTP_REQUEST_LOG_OMIT_RESPONSE_BODY=true
HTTP_REQUEST_LOG_OMIT_REQUEST_HEADERS=true
HTTP_REQUEST_LOG_OMIT_RESPONSE_HEADERS=true
HTTP_REQUEST_LOG_MAX_BODY_BYTES=4096

# Rate limit — 3 tiers
#   strict  → auth endpoints (login, register, password reset)
#   default → regular API routes
#   skip    → do not attach middleware (health, metrics, etc.)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STRICT_PER_MINUTE=10
RATE_LIMIT_DEFAULT_PER_SECOND=100

# ============================================================================
# Database (primary — required)
# ============================================================================
DB_DRIVER=mysql                                   # mysql | postgres
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=
DB_PARAMS=
DB_INSTANCE=                                      # GCP Cloud SQL instance (leave empty for TCP)
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10
DB_MAX_LIFETIME_MINUTES=30

# Secondary database (optional)
DB2_ENABLED=false
DB2_DRIVER=mysql
DB2_HOST=
DB2_PORT=3306
DB2_USER=
DB2_PASSWORD=
DB2_NAME=
DB2_INSTANCE=
DB2_MAX_OPEN_CONNS=25
DB2_MAX_IDLE_CONNS=10
DB2_MAX_LIFETIME_MINUTES=30

# Migrations
MIGRATIONS_ENABLED=true
MIGRATIONS_PATH=migrations

# ============================================================================
# Redis
# ============================================================================
REDIS_ENABLED=true
REDIS_ADDR=127.0.0.1:6379
REDIS_PASSWORD=
REDIS_DB=0

# ============================================================================
# MongoDB
# ============================================================================
MONGO_ENABLED=false
MONGO_URI=
MONGO_DATABASE=middleware

# ============================================================================
# Firebase (Firestore + Auth + FCM)
# ============================================================================
FIREBASE_CREDENTIALS=                             # path to firebase-key.json (firestore + auth)
FIREBASE_NOTIFICATION_CREDENTIALS=                # path to FCM service account (can be same file)

# ============================================================================
# Google Cloud
# ============================================================================
GCP_PROJECT_ID=
GOOGLE_CLOUD_PROJECT=                             # set automatically on GAE; used to build GAE URLs

# Pub/Sub
PUBSUB_ENABLED=false
PUBSUB_PROJECT_ID=
PUBSUB_CREDENTIALS_FILE=

# Cloud Storage
STORAGE_ENABLED=false
STORAGE_BUCKET=
STORAGE_CREDENTIALS_FILE=
BUCKET=                                           # legacy bucket name read by AppInfo

# ============================================================================
# Mail (Mailgun)
# ============================================================================
MAIL_ENABLED=false
MAILGUN_DOMAIN=
MAILGUN_API_KEY=

# ============================================================================
# Auth / JWT
# ============================================================================
JWT_SECRET=                                       # required
JWT_REFRESH_SECRET=                               # optional, used by legacy refresh tokens
JWT_BLACKLIST_ENABLED=false

# ============================================================================
# OTP / SMS (ThaiBulkSMS or similar)
# ============================================================================
OTP_URL_REQUEST=
OTP_URL_VERIFY=
OTP_SMS_KEY=
OTP_SMS_SECRET=

# ============================================================================
# 2C2P payment
# ============================================================================
PAYMENT_2C2P_SECRET=
PAYMENT_2C2P_MERCHANT_ID=
PAYMENT_2C2P_REQUEST_URL=
PAYMENT_2C2P_INQUIRY_URL=
PAYMENT_2C2P_REFUND_URL=

# ============================================================================
# Upload service (internal file upload API)
# ============================================================================
UPLOAD_SERVICE_URL=
UPLOAD_TOKEN=

# ============================================================================
# Observability (optional)
# ============================================================================
LOG_LEVEL=info                                    # debug | info | warn | error | critical

# Sentry (see infra/sentry.go for keys)
# SENTRY_DSN=
# SENTRY_ENV=

# OpenTelemetry (see infra/otel.go for keys)
# OTEL_EXPORTER_OTLP_ENDPOINT=
